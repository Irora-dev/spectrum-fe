# RPC precedence per chain: explicit *_RPC_URL  →  Alchemy key  →  public fallback.
#
# Single Alchemy key powers both chains (enable ETH + Base on the key).
# WARNING: this is a static client build — any value here ships in the public
# bundle. A key set below is PUBLIC. Prefer leaving it empty (public RPC), an
# origin-restricted key, or a read proxy you control.
VITE_ALCHEMY_API_KEY=

# Optional explicit overrides (take precedence over the Alchemy key):
VITE_BASE_RPC_URL=
VITE_MAINNET_RPC_URL=

# WalletConnect Cloud project id (optional — injected wallets work without it)
VITE_WALLETCONNECT_PROJECT_ID=
